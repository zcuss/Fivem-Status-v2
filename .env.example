# =========================
# CORE
# =========================
NODE_ENV=development
CLUSTER_ID=default

# =========================
# DATABASE (pick one)
# =========================
# DB_TYPE=sqlite|mysql|postgres|cockroach

# --- SQLite ---
DB_TYPE=sqlite
SQLITE_PATH=./data/fivem.db

# --- MySQL ---
# DB_TYPE=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASS=
# DB_NAME=Fivem_Status

# --- CockroachDB ---
# DB_TYPE=cockroach
# DATABASE_URL=postgresql://user:pass@host:26257/dbname?sslmode=no-verify

# --- Postgres ---
# DB_TYPE=postgres
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Supabase ---
# DB_TYPE=postgres
# DATABASE_URL=postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:6543/postgres

# --- Neon ---
# DB_TYPE=postgres
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

DB_POOL_MAX=15
DB_CONNECT_TIMEOUT_MS=5000
DB_QUERY_TIMEOUT_MS=5000
DB_QUERY_RETRIES=2
DB_QUERY_RETRY_BASE_MS=250
DB_SSL=false

# =========================
# DISCORD BOT (legacy single-bot mode)
# =========================
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=http://localhost:34001/callback
SESSION_SECRET=change-me

BOT_AUTHOR=ZCUS
BOT_INTERVAL_MS=10000
BOT_GUILD_CACHE=true

ADMIN_IDS=
OWNER_IDS=
DEFAULT_USER_LOGO=https://cdn.discordapp.com/emojis/1463404966801838080.gif?size=128

# =========================
# DASHBOARD
# =========================
DASHBOARD_PORT=34001
DASHBOARD_HOST=0.0.0.0

# =========================
# API
# =========================
API_PORT=34002
API_HOST=0.0.0.0

# =========================
# VOICE
# =========================
VOICE_SYNC_ENABLED=true
VOICE_SYNC_INTERVAL_MS=10000

# =========================
# STEAM SELF BOT
# =========================
STEAM=false
STEAM_SELF_TOKEN=
STEAM_GUILD_ID=
STEAM_CHANNEL_ID=
STEAM_READONLY=true
STEAM_IGNORE_BOTS=true
STEAM_ALLOW_WEBHOOK=true
STEAM_FORWARD_WEBHOOK_URL=
STEAM_BACKFILL_DAYS=0
STEAM_BACKFILL_LIMIT=5000
STEAM_FETCH_DELAY_MS_MIN=800
STEAM_FETCH_DELAY_MS_MAX=1600

# =========================
# MIGRATION (MySQL → CockroachDB)
# =========================
# MIGRATION_SOURCE_DSN=mysql://user:pass@host:3306/dbname
# MIGRATION_TARGET_DSN=postgresql://user:pass@host:26257/dbname?sslmode=no-verify

# =========================
# MIDTRANS (billing)
# =========================
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
