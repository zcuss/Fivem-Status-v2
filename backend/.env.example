# =========================
# CORE
# =========================
NODE_ENV=development
CLUSTER_ID=default

# =========================
# DATABASE (pick one)
# =========================
# --- SQLite ---
DB_TYPE=sqlite
SQLITE_PATH=./data/fivem.db

# --- MySQL ---
# DB_TYPE=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASS=
# DB_NAME=Fivem_Status

# --- CockroachDB ---
# DB_TYPE=cockroach
# DATABASE_URL=postgresql://user:***@host:26257/dbname?sslmode=no-verify

# --- Postgres ---
# DB_TYPE=postgres
# DATABASE_URL=postgresql://user:***@host:5432/dbname

DB_POOL_MAX=15
DB_CONNECT_TIMEOUT_MS=5000
DB_QUERY_TIMEOUT_MS=5000
DB_QUERY_RETRIES=2
DB_QUERY_RETRY_BASE_MS=250
DB_SSL=false

# =========================
# DISCORD BOT
# =========================
DISCORD_TOKEN=
BOT_AUTHOR=ZCUS
BOT_INTERVAL_MS=10000
BOT_GUILD_CACHE=true
BOT_INVITE_PERMISSIONS=8

ADMIN_IDS=
OWNER_IDS=
DEFAULT_USER_LOGO=https://cdn.discordapp.com/emojis/1463404966801838080.gif?size=128

# =========================
# API
# =========================
API_PORT=34002
API_HOST=0.0.0.0

# =========================
# VOICE
# =========================
VOICE_SYNC_ENABLED=true
VOICE_SYNC_INTERVAL_MS=10000

# =========================
# STEAM SELF BOT
# =========================
STEAM=false
STEAM_SELF_TOKEN=
STEAM_GUILD_ID=
STEAM_CHANNEL_ID=
STEAM_READONLY=true
STEAM_IGNORE_BOTS=true
STEAM_ALLOW_WEBHOOK=true
STEAM_FORWARD_WEBHOOK_URL=
STEAM_BACKFILL_DAYS=0
STEAM_BACKFILL_LIMIT=5000
STEAM_FETCH_DELAY_MS_MIN=800
STEAM_FETCH_DELAY_MS_MAX=1600

# =========================
# MIGRATION (MySQL -> CRDB)
# =========================
# MIGRATION_SOURCE_DSN=mysql://user:***@host:3306/dbname
# MIGRATION_TARGET_DSN=postgresql://user:***@host:26257/dbname?sslmode=no-verify

# =========================
# MIDTRANS (billing)
# =========================
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
